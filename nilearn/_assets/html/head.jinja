<!DOCTYPE html>
<html lang="en">
    <head>
        <title>Nilearn - {{ page_title }}</title>
        <link rel="icon"
              type="image/x-icon"
              href="https://raw.githubusercontent.com/nilearn/nilearn/main/doc/logos/favicon.ico" />
        <meta name="viewport"
              content="width = device-width, initial-scale = 1"
              charset="UTF-8" />
        {% if head_css %}
            <!-- djlint:off --><style type="text/css">{% include "css/head.css" %}</style><!-- djlint:on -->
        {% endif %}
        <!-- djlint:off --><style type="text/css">{% block extra_css %}{% endblock extra_css %}</style><!-- djlint:on -->

        {% block script %}
        {% endblock script %}

    </head>
    <body>
        <main>
            {{ body }}

            {% block main %}
            {% endblock main %}

        </main>
        <footer {{ display_footer }}>
            <address>
                <p>
                    Built using
                    <a href="https://nilearn.github.io">Nilearn (version={{ version }})</a>.
                    Source code on
                    <a href="https://github.com/nilearn/nilearn">GitHub</a>. File bugs
                    &amp; feature requests
                    <a href="https://github.com/nilearn/nilearn/issues">here</a>.
                </p>
            </address>
        </footer>
    </body>
    
        {% block endscript %}
        {% endblock endscript %}

</html>
